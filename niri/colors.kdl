layout {
    border {
        active-color   "#9ccaff"
        inactive-color "#8a919c"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#9ccaff"
        inactive-color "#8a919c"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#9ccaff80"
    }
}

