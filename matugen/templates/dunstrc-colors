[global]
monitor = 0
follow = none
width = 360
origin = top-right
offset = 20x20
notification_limit = 5

progress_bar = false

padding = 16
horizontal_padding = 16
text_icon_padding = 12

frame_width = 2
frame_color = "{{colors.primary.default.hex}}"

separator_height = 2
separator_color = "{{colors.outline.default.hex}}"

font = "JetBrainsMono NF 12"
markup = full
format = "<b>%s</b>\n<span fgcolor='{{colors.primary.default.hex}}'>%b</span>"
highlight = "{{colors.primary.default.hex}}"

alignment = left
vertical_alignment = center

show_indicators = no

icon_position = left
min_icon_size = 32
max_icon_size = 68

corner_radius = 12

[urgency_low]
timeout = 3
background = "{{colors.surface.default.hex}}"
foreground = "{{colors.on_surface.default.hex}}"
highlight = "{{colors.primary_container.default.hex}}"

[urgency_normal]
timeout = 6
background = "{{colors.surface.default.hex}}"
foreground = "{{colors.on_surface.default.hex}}"
highlight = "{{colors.primary_container.default.hex}}"

[urgency_critical]
timeout = 0
background = "{{colors.surface.default.hex}}"
foreground = "{{colors.on_surface.default.hex}}"
highlight = "{{colors.error.default.hex}}"

