# =========================
# Kitty Config - Minimal
# =========================

# Window Appearance
background_opacity      0.8
background_blur         1
window_padding_width    6.0

# Fonts
font_family             Fira Code Nerd Font
bold_font               auto
italic_font             auto
bold_italic_font        auto
font_size               14.0
disable_ligatures       never



# Splits
map ctrl+shift+enter     launch --location=hsplit
map ctrl+shift+backspace launch --location=vsplit
map ctrl+shift+w         close_window
map ctrl+shift+h         neighboring_window left
map ctrl+shift+l         neighboring_window right
map ctrl+shift+k         neighboring_window up
map ctrl+shift+j         neighboring_window down
map ctrl+shift+alt+h     resize_window narrower 5
map ctrl+shift+alt+l     resize_window wider 5
map ctrl+shift+alt+k     resize_window taller 5
map ctrl+shift+alt+j     resize_window shorter 5

# Mouse / URL Handling
allow_remote_control     yes
open_url_with            waterfox

# Include colors / theme
include colors.conf
include current-theme.conf




# BEGIN_KITTY_THEME
# Matugen
# END_KITTY_THEME
